<Application
    x:Class="QPARKShot.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    StartupUri="MainWindow.xaml"
    ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="QPARKAccent" Color="#FF0A84FF" />
            <SolidColorBrush x:Key="CardFill" Color="#10FFFFFF" />
            <SolidColorBrush x:Key="CardStroke" Color="#22FFFFFF" />
            <SolidColorBrush x:Key="SidebarFill" Color="#10000000" />
            <SolidColorBrush x:Key="SecondaryText" Color="#99FFFFFF" />
            <SolidColorBrush x:Key="DividerStroke" Color="#22FFFFFF" />

            <!-- Card style for settings sections -->
            <Style x:Key="SettingsCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource CardFill}" />
                <Setter Property="BorderBrush" Value="{StaticResource CardStroke}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="14" />
            </Style>

            <!-- Flat icon-style button -->
            <Style x:Key="IconButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="6" />
                <Setter Property="Foreground" Value="{StaticResource SecondaryText}" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#22FFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
