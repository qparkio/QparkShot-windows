<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="QPARKShot.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Click="OnBack" Background="Transparent" Padding="12,10,12,6">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72B;" FontFamily="Segoe Fluent Icons" FontSize="11" />
                    <TextBlock Text="Gallery" FontSize="12" />
                </StackPanel>
            </Button>

            <StackPanel Grid.Row="1" Spacing="2" Padding="12,16,12,8">
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,12">
                    <FontIcon Glyph="&#xE722;" FontFamily="Segoe Fluent Icons" FontSize="22"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                    <StackPanel>
                        <TextBlock Text="QPARK Shot" FontSize="13" FontWeight="Bold" />
                        <TextBlock Text="Preferences" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <RadioButtons x:Name="TabSelector" SelectionChanged="OnTabChanged" SelectedIndex="0">
                    <RadioButton Content="Appearance" Tag="appearance" />
                    <RadioButton Content="Hotkeys" Tag="hotkeys" />
                    <RadioButton Content="Watermark" Tag="watermark" />
                    <RadioButton Content="Storage" Tag="storage" />
                    <RadioButton Content="Buffer" Tag="buffer" />
                    <RadioButton Content="About" Tag="about" />
                </RadioButtons>
            </StackPanel>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Column="1" Padding="20">
            <StackPanel x:Name="ContentRoot" Spacing="14" />
        </ScrollViewer>
    </Grid>
</Page>
