<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="QPARKShot.Views.ShotQueueSidebar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QPARKShot.Views">
    <Grid Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6"
                    Padding="10,8,8,8" VerticalAlignment="Center">
            <FontIcon Glyph="&#xE74C;" FontFamily="Segoe Fluent Icons" FontSize="12"
                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            <TextBlock x:Name="HeaderText" Text="Buffer · 0" FontWeight="SemiBold" FontSize="11" />
            <Button x:Name="ClearAllButton" Click="OnClearAll" Padding="4" Margin="6,0,0,0"
                    Background="Transparent" ToolTipService.ToolTip="Clear buffer">
                <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="10" />
            </Button>
        </StackPanel>

        <Border Grid.Row="1" Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsRepeater x:Name="QueueRepeater" Margin="8" />
        </ScrollViewer>
    </Grid>
</UserControl>
