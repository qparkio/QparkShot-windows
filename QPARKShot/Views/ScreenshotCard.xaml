<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="QPARKShot.Views.ScreenshotCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Width="160" Height="130" CanDrag="True" DragStarting="OnDragStarting" Tapped="OnTapped">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" CornerRadius="6" Background="#33000000">
            <Image x:Name="Thumb" Stretch="UniformToFill" />
            <Border x:Name="HoverOverlay" Background="#66000000" Visibility="Collapsed">
                <Button Click="OnDelete" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="6" Padding="4" Background="#FFD13030">
                    <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" FontSize="11" Foreground="White" />
                </Button>
            </Border>
        </Grid>

        <TextBlock Grid.Row="1" x:Name="NameText" FontSize="10"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   TextTrimming="CharacterEllipsis" Margin="2,4,2,0" />
    </Grid>
</UserControl>
