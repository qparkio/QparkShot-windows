<UserControl
    x:Class="QPARKShot.Views.ScreenshotCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="170" Height="140" Margin="6">
    <Grid x:Name="RootGrid" MouseLeftButtonUp="OnTapped" Cursor="Hand"
          MouseEnter="OnHoverEnter" MouseLeave="OnHoverExit"
          PreviewMouseMove="OnPreviewMouseMove" PreviewMouseLeftButtonDown="OnPreviewMouseDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Edit" Click="OnTapped" />
                <MenuItem Header="Copy to Clipboard" Click="OnCopyClipboard" />
                <MenuItem Header="Show in Explorer" Click="OnShowInExplorer" />
                <Separator />
                <MenuItem Header="Delete" Click="OnDelete" />
            </ContextMenu>
        </Grid.ContextMenu>

        <Border Grid.Row="0" CornerRadius="6" Background="#33000000" ClipToBounds="True">
            <Grid>
                <Image x:Name="Thumb" Stretch="UniformToFill" />
                <Border x:Name="HoverOverlay" Background="#66000000" Visibility="Collapsed">
                    <Button Click="OnDelete" HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="6" Padding="6,4" Background="#D13030" Foreground="White"
                            BorderThickness="0">
                        <TextBlock Text="🗑" FontSize="10" />
                    </Button>
                </Border>
            </Grid>
        </Border>

        <TextBlock Grid.Row="1" x:Name="NameText" FontSize="10"
                   Foreground="{StaticResource SecondaryText}"
                   TextTrimming="CharacterEllipsis" Margin="2,4,2,0" />
    </Grid>
</UserControl>
