<Page
    x:Class="QPARKShot.Views.GalleryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:QPARKShot.Views"
    Background="Transparent"
    Title="Gallery">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Click="OnCapture" Padding="10,5" Margin="6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📸" Margin="0,0,6,0" />
                        <TextBlock Text="Capture" />
                    </StackPanel>
                </Button>
                <Button Click="OnSettings" Padding="10,5" Margin="6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙" Margin="0,0,6,0" />
                        <TextBlock Text="Preferences" />
                    </StackPanel>
                </Button>
                <Button Click="OnClearCache" Padding="8,5" Margin="6,0" ToolTip="Clear temp cache">
                    <TextBlock Text="🗑" />
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <TextBlock x:Name="EmptyState"
                           Text="No screenshots yet. Press Ctrl+Shift+C or use the Capture button."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryText}"
                           Visibility="Collapsed" Margin="0,80,0,0" />

                <ItemsControl x:Name="GalleryItems" Margin="16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:ScreenshotCard />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
